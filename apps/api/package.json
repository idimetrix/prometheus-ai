{
  "name": "@prometheus/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/trpc-server": "^0.4.2",
    "hono": "^4.12.9",
    "@trpc/server": "^11.15.0",
    "superjson": "^2.2.6",
    "zod": "^4.3.6",
    "@prometheus/db": "workspace:*",
    "@prometheus/auth": "workspace:*",
    "@prometheus/billing": "workspace:*",
    "@prometheus/types": "workspace:*",
    "@prometheus/validators": "workspace:*",
    "@prometheus/logger": "workspace:*",
    "@prometheus/queue": "workspace:*",
    "@prometheus/telemetry": "workspace:*",
    "@prometheus/utils": "workspace:*",
    "@sentry/node": "^10.45.0",
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "@prometheus/config-typescript": "workspace:*",
    "tsx": "^4.21.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
