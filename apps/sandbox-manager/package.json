{
  "name": "@prometheus/sandbox-manager",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "hono": "^4.12.8",
    "@hono/node-server": "^1.19.11",
    "dockerode": "^4.0.9",
    "@prometheus/logger": "workspace:*",
    "@prometheus/telemetry": "workspace:*",
    "@prometheus/types": "workspace:*",
    "@prometheus/queue": "workspace:*",
    "@prometheus/utils": "workspace:*"
  },
  "devDependencies": {
    "@prometheus/config-typescript": "workspace:*",
    "@types/dockerode": "^4.0.1",
    "tsx": "^4.21.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
