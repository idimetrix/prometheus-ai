{
  "name": "@prometheus/orchestrator",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "hono": "^4.12.8",
    "@hono/node-server": "^1.19.11",
    "ai": "^6.0.116",
    "drizzle-orm": "^0.45.1",
    "ioredis": "5.10.1",
    "@prometheus/db": "workspace:*",
    "@prometheus/types": "workspace:*",
    "@prometheus/queue": "workspace:*",
    "@prometheus/ai": "workspace:*",
    "@prometheus/agent-sdk": "workspace:*",
    "@prometheus/logger": "workspace:*",
    "@prometheus/telemetry": "workspace:*",
    "@prometheus/utils": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@prometheus/config-typescript": "workspace:*",
    "tsx": "^4.21.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
