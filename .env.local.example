# ============================================================================
# Prometheus — Minimal Local Development Config
# ============================================================================
# Copy to .env and start developing:
#   cp .env.local.example .env
#   docker compose up -d    # Start Postgres + Redis + MinIO
#   pnpm install && pnpm db:push && pnpm dev
#
# This file contains ONLY the variables needed for basic local development.
# For the full list of options, see .env.example
# ============================================================================

# ── Dev Mode ────────────────────────────────────────────────────────────────
# Bypass Clerk auth — use Bearer tokens like: dev_token_<userId>__<orgId>
# Example: Authorization: Bearer dev_token_usr_seed_dev001__org_seed_dev001
DEV_AUTH_BYPASS=true
NEXT_PUBLIC_DEV_AUTH_BYPASS=true

# Set to true to return canned LLM responses (no API keys needed at all)
DEV_MOCK_LLM=false

# Use AI SDK 6 ToolLoopAgent for agent execution (recommended)
PROMETHEUS_USE_AI_SDK=true

NODE_ENV=development
LOG_LEVEL=debug

# ── Database (required) ────────────────────────────────────────────────────
# Local Postgres from docker compose
DATABASE_URL=postgresql://prometheus:prometheus_dev@localhost:5432/prometheus

# ── Redis (required) ──────────────────────────────────────────────────────
# Local Redis from docker compose
REDIS_URL=redis://localhost:6379

# ── Encryption (required) ─────────────────────────────────────────────────
# 64-char hex string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── LLM API Keys ──────────────────────────────────────────────────────────
# At least ONE key is needed for real LLM responses (or set DEV_MOCK_LLM=true).
# Cerebras and Groq both have free tiers — pick one or both.

# [RECOMMENDED — free tier] Cerebras fast inference
CEREBRAS_API_KEY=

# [RECOMMENDED — free tier] Groq fast inference
GROQ_API_KEY=

# [OPTIONAL — free tier] Google Gemini for long context
GEMINI_API_KEY=

# [OPTIONAL — paid] Anthropic Claude for premium tasks
ANTHROPIC_API_KEY=

# [OPTIONAL — paid] OpenAI
OPENAI_API_KEY=

# Local Ollama for embeddings (runs on your machine, no key needed)
OLLAMA_BASE_URL=http://localhost:11434

# ── App & Service URLs ────────────────────────────────────────────────────
# Web frontend
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
WEB_URL=http://localhost:3000

# API server
NEXT_PUBLIC_API_URL=http://localhost:4000
API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000

# WebSocket server
NEXT_PUBLIC_SOCKET_URL=http://localhost:4001
NEXT_PUBLIC_WS_URL=ws://localhost:4001
SOCKET_SERVER_URL=http://localhost:4001

# MCP Gateway (for plugin health checks in UI)
NEXT_PUBLIC_MCP_GATEWAY_URL=http://localhost:4005

# Internal services
ORCHESTRATOR_URL=http://localhost:4002
PROJECT_BRAIN_URL=http://localhost:4003
MODEL_ROUTER_URL=http://localhost:4004
MCP_GATEWAY_URL=http://localhost:4005
SANDBOX_MANAGER_URL=http://localhost:4006

# ── Service Ports ─────────────────────────────────────────────────────────
PORT=4000
SOCKET_PORT=4001
ORCHESTRATOR_PORT=4002
PROJECT_BRAIN_PORT=4003
MODEL_ROUTER_PORT=4004
MCP_GATEWAY_PORT=4005
SANDBOX_MANAGER_PORT=4006

# ── Sandbox (dev mode — no Docker needed) ─────────────────────────────────
SANDBOX_MODE=dev
