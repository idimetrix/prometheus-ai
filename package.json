{
  "name": "prometheus",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:push": "turbo run db:push --filter=@prometheus/db",
    "db:migrate": "turbo run db:migrate --filter=@prometheus/db",
    "db:generate": "turbo run db:generate --filter=@prometheus/db",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.7.0",
    "prettier": "^3.5.0",
    "@types/node": "^22.0.0",
    "vitest": "^3.2.0"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "msgpackr-extract",
      "@clerk/shared",
      "cpu-features",
      "protobufjs",
      "ssh2"
    ],
    "overrides": {
      "ioredis": "5.9.3"
    }
  }
}