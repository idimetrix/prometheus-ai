{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": [
    "ultracite/biome/core",
    "ultracite/biome/react",
    "ultracite/biome/next"
  ],
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "!**/node_modules",
      "!**/.next",
      "!**/.claude",
      "!**/.agents",
      "!**/dist",
      "!**/build",
      "!**/skills",
      "!**/src/components/ui",
      "!**/src/components/ai-elements",
      "!**/.turbo",
      "!**/drizzle",
      "!**/coverage",
      "!**/*.min.js",
      "!infra/k6",
      "!infra/scripts/load-tests",
      "!tests/load"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noUnknownAtRules": "off",
        "noExplicitAny": "error",
        "noBitwiseOperators": "off",
        "noControlCharactersInRegex": "off"
      },
      "performance": {
        "noBarrelFile": "off",
        "noNamespaceImport": "off"
      },
      "security": {
        "noDangerouslySetInnerHtml": "off"
      },
      "a11y": {
        "noNoninteractiveElementInteractions": "off",
        "noStaticElementInteractions": "off",
        "noNoninteractiveTabindex": "off",
        "useSemanticElements": "off"
      }
    },
    "domains": {
      "next": "recommended",
      "react": "recommended"
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": []
}
