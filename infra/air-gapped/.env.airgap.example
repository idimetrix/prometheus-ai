# =============================================================================
# Prometheus AI Platform — Air-Gapped Environment Configuration
# =============================================================================
# Copy this file to .env.airgap and adjust as needed.
# No external API keys are required. All LLM inference runs locally via Ollama.
# =============================================================================

# ── Infrastructure ────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=prometheus_airgap
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── LiteLLM (local model proxy) ──────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-prometheus-airgap

# ── Inngest (local job orchestration) ─────────────────────────────────────────
INNGEST_EVENT_KEY=airgap-event-key
INNGEST_SIGNING_KEY=airgap-signing-key

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
DATABASE_URL=postgresql://prometheus:prometheus_airgap@pgbouncer:6432/prometheus
REDIS_URL=redis://redis:6379

# ── Auth (local-only, self-signed) ────────────────────────────────────────────
# Generate a random secret: openssl rand -hex 32
AUTH_SECRET=change-me-to-a-random-secret
NEXTAUTH_URL=http://localhost:3000

# ── Service URLs (internal docker network) ────────────────────────────────────
API_URL=http://api:4000
ORCHESTRATOR_URL=http://orchestrator:4002
PROJECT_BRAIN_URL=http://project-brain:4003
MODEL_ROUTER_URL=http://model-router:4004
MCP_GATEWAY_URL=http://mcp-gateway:4005
SANDBOX_MANAGER_URL=http://sandbox-manager:4006
SOCKET_SERVER_URL=http://socket-server:4001

# ── Ollama (local LLM) ───────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434

# ── Telemetry (disabled in air-gapped mode) ───────────────────────────────────
TELEMETRY_DISABLED=true
SENTRY_DSN=
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
