# =============================================================================
# Prometheus Air-Gapped Environment Configuration
# =============================================================================
# All URLs point to internal Docker services. No external API keys required.
# =============================================================================

# ── General ──────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
AIR_GAPPED=true

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://prometheus:prometheus_airgap@pgbouncer:6432/prometheus
POSTGRES_PASSWORD=prometheus_airgap

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Encryption ───────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_REAL_KEY

# ── LLM — Ollama Only (no external API keys) ────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
LITELLM_URL=http://litellm:4000
LITELLM_MASTER_KEY=sk-prometheus-airgap

# ── App URLs (internal Docker network) ───────────────────────────────────────
APP_URL=http://web:3000
NEXT_PUBLIC_API_URL=http://api:4000
NEXT_PUBLIC_SOCKET_URL=http://socket-server:4001
API_URL=http://api:4000
CORS_ORIGIN=http://web:3000

# ── Service URLs (internal Docker network) ───────────────────────────────────
ORCHESTRATOR_URL=http://orchestrator:4002
PROJECT_BRAIN_URL=http://project-brain:4003
MODEL_ROUTER_URL=http://model-router:4004
MCP_GATEWAY_URL=http://mcp-gateway:4005
SANDBOX_MANAGER_URL=http://sandbox-manager:4006

# ── Service Ports ────────────────────────────────────────────────────────────
PORT=4000
SOCKET_PORT=4001
ORCHESTRATOR_PORT=4002
PROJECT_BRAIN_PORT=4003
MODEL_ROUTER_PORT=4004
MCP_GATEWAY_PORT=4005
SANDBOX_MANAGER_PORT=4006

# ── Inngest ──────────────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=airgap-event-key
INNGEST_SIGNING_KEY=airgap-signing-key
INNGEST_BASE_URL=http://inngest:8288

# ── Object Storage (MinIO) ──────────────────────────────────────────────────
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_BUCKET=prometheus-artifacts
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# ── Code Search ──────────────────────────────────────────────────────────────
ZOEKT_URL=http://zoekt:6070

# ── Embedding ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=nomic-embed-text

# ── Worker Config ────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=2
ENTERPRISE_CONCURRENCY=4

# ── Sandbox Manager Config ──────────────────────────────────────────────────
WARM_POOL_SIZE=2
MAX_POOL_SIZE=10
SANDBOX_IDLE_TTL_MS=1800000
SANDBOX_IMAGE=node:22-alpine
SANDBOX_BASE_DIR=/tmp/prometheus-sandboxes

# ── Auth (disabled in air-gapped mode — use local auth) ─────────────────────
AUTH_MODE=local
LOCAL_ADMIN_EMAIL=admin@localhost
LOCAL_ADMIN_PASSWORD=CHANGE_ME

# ── External services disabled ──────────────────────────────────────────────
# No Clerk, Stripe, Resend, Sentry, or external LLM API keys needed
