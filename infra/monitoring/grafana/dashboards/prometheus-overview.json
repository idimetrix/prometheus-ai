{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Active Sessions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "prometheus_orchestrator_active_sessions",
          "legendFormat": "sessions"
        }
      ]
    },
    {
      "title": "Agent Duration P50/P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(prometheus_agent_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.99, rate(prometheus_agent_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Model Latency P50/P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(prometheus_model_latency_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.99, rate(prometheus_model_latency_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        { "expr": "prometheus_queue_depth", "legendFormat": "{{queue}}" }
      ]
    },
    {
      "title": "Credit Consumption Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "rate(prometheus_credits_consumed_total[5m])",
          "legendFormat": "credits/sec"
        }
      ]
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "rate(prometheus_queue_failed_total[5m])",
          "legendFormat": "queue failures/sec"
        },
        {
          "expr": "rate(prometheus_model_fallback_total[5m])",
          "legendFormat": "model fallbacks/sec"
        }
      ]
    },
    {
      "title": "Model Requests by Slot",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "prometheus_model_requests_total",
          "legendFormat": "{{slot}}"
        }
      ]
    },
    {
      "title": "Token Consumption",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "rate(prometheus_model_tokens_total[5m])",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "title": "Active Sandboxes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 16 },
      "targets": [
        {
          "expr": "prometheus_sandbox_active_count",
          "legendFormat": "sandboxes"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["prometheus-platform"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Prometheus Platform Overview",
  "uid": "prometheus-overview"
}
