# Production Secrets Template
# Copy to production.yaml and encrypt with SOPS:
#   cp production.yaml.example production.yaml
#   # Fill in values
#   sops --encrypt --in-place production.yaml

# Database
DATABASE_URL: "postgresql://prometheus:CHANGE_ME@postgres:5432/prometheus"
REDIS_URL: "redis://redis:6379"

# Authentication (Clerk)
CLERK_SECRET_KEY: "sk_live_CHANGE_ME"
CLERK_WEBHOOK_SECRET: "whsec_CHANGE_ME"

# Billing (Stripe)
STRIPE_SECRET_KEY: "sk_live_CHANGE_ME"
STRIPE_WEBHOOK_SECRET: "whsec_CHANGE_ME"

# LLM Providers
CEREBRAS_API_KEY: ""
GROQ_API_KEY: ""
GEMINI_API_KEY: ""
OPENROUTER_API_KEY: ""
MISTRAL_API_KEY: ""
DEEPSEEK_API_KEY: ""
ANTHROPIC_API_KEY: ""
OPENAI_API_KEY: ""

# Encryption
ENCRYPTION_KEY: "" # Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Email
RESEND_API_KEY: ""

# Monitoring
SENTRY_DSN: ""

# Analytics
POSTHOG_API_KEY: ""
LANGFUSE_PUBLIC_KEY: ""
LANGFUSE_SECRET_KEY: ""
