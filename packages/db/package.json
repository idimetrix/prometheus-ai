{
  "name": "@prometheus/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:run": "tsx src/migrate.ts",
    "db:ensure-extensions": "tsx src/ensure-extensions.ts",
    "db:push": "pnpm db:ensure-extensions && drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check",
    "db:drop": "drizzle-kit drop",
    "db:reset": "pnpm db:ensure-extensions && drizzle-kit push --force-reset",
    "db:fresh": "pnpm db:drop && rm -rf drizzle && pnpm db:ensure-extensions && drizzle-kit push --force && pnpm db:seed",
    "db:setup": "pnpm db:generate && pnpm db:ensure-extensions && pnpm db:migrate",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@prometheus/logger": "workspace:*",
    "@prometheus/utils": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "postgres": "^3.4.8",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@prometheus/config-typescript": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2"
  }
}
