{
  "name": "prometheus-vscode",
  "displayName": "Prometheus AI",
  "description": "AI-powered engineering assistant with 12 specialist agents. Automate code reviews, refactoring, testing, and deployments directly from VS Code.",
  "version": "0.1.0",
  "publisher": "prometheus",
  "license": "MIT",
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/prometheus-platform/prometheus"
  },
  "homepage": "https://prometheus.dev",
  "bugs": {
    "url": "https://github.com/prometheus-platform/prometheus/issues"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Machine Learning",
    "Testing",
    "Linters"
  ],
  "keywords": [
    "ai",
    "agent",
    "engineering",
    "prometheus",
    "code-review",
    "refactoring",
    "testing",
    "deployment",
    "copilot",
    "assistant"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:prometheus.startSession",
    "onCommand:prometheus.openChat",
    "onView:prometheus.chatPanel"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "prometheus.startSession",
        "title": "Prometheus: Start Session"
      },
      {
        "command": "prometheus.openChat",
        "title": "Prometheus: Open Chat"
      },
      {
        "command": "prometheus.assignTask",
        "title": "Prometheus: Assign Task"
      },
      {
        "command": "prometheus.submitTask",
        "title": "Prometheus: Submit Task"
      },
      {
        "command": "prometheus.showDashboard",
        "title": "Prometheus: Show Dashboard"
      },
      {
        "command": "prometheus.approveCheckpoint",
        "title": "Prometheus: Approve Checkpoint"
      },
      {
        "command": "prometheus.viewStatus",
        "title": "Prometheus: View Agent Status"
      },
      {
        "command": "prometheus.stopSession",
        "title": "Prometheus: Stop Session"
      },
      {
        "command": "prometheus.configure",
        "title": "Prometheus: Configure API Settings"
      },
      {
        "command": "prometheus.explainCode",
        "title": "Prometheus: Explain this code"
      },
      {
        "command": "prometheus.refactorCode",
        "title": "Prometheus: Refactor this"
      },
      {
        "command": "prometheus.addTests",
        "title": "Prometheus: Add tests"
      },
      {
        "command": "prometheus.fixCode",
        "title": "Prometheus: Fix this"
      },
      {
        "command": "prometheus.optimizeCode",
        "title": "Prometheus: Optimize"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "prometheus",
          "title": "Prometheus",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "prometheus": [
        {
          "type": "webview",
          "id": "prometheus.chatPanel",
          "name": "Agent Chat"
        },
        {
          "id": "prometheus.sessions",
          "name": "Active Sessions"
        },
        {
          "id": "prometheus.agents",
          "name": "Agent Status"
        },
        {
          "id": "prometheus.tasks",
          "name": "Recent Tasks"
        }
      ]
    },
    "configuration": {
      "title": "Prometheus",
      "properties": {
        "prometheus.apiUrl": {
          "type": "string",
          "default": "http://localhost:4000",
          "description": "URL of the Prometheus API server"
        },
        "prometheus.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for authentication. Can also be stored in VS Code Secret Storage."
        },
        "prometheus.socketUrl": {
          "type": "string",
          "default": "ws://localhost:4001",
          "description": "URL of the Prometheus WebSocket server"
        },
        "prometheus.apiToken": {
          "type": "string",
          "default": "",
          "description": "Legacy API authentication token (use apiKey instead)",
          "deprecationMessage": "Use prometheus.apiKey instead"
        },
        "prometheus.inlineCompletions.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline code completions (ghost text suggestions)"
        },
        "prometheus.inlineCompletions.debounceMs": {
          "type": "number",
          "default": 300,
          "minimum": 100,
          "maximum": 2000,
          "description": "Debounce delay in milliseconds before requesting inline completions"
        },
        "prometheus.defaultModel": {
          "type": "string",
          "default": "auto",
          "description": "Default model to use for completions and chat (e.g., 'auto', 'gpt-4', 'claude-3')"
        },
        "prometheus.telemetry.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Allow anonymous usage telemetry to help improve Prometheus"
        }
      }
    },
    "keybindings": [
      {
        "command": "prometheus.openChat",
        "key": "ctrl+shift+p",
        "mac": "cmd+shift+p",
        "when": "prometheus.sessionActive"
      }
    ]
  },
  "scripts": {
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@prometheus/config-typescript": "workspace:*",
    "@types/vscode": "^1.110.0",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "typescript": "^6.0.2"
  }
}
