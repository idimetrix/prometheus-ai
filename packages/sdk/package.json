  },
  "keywords": [
    "prometheus",
    "sdk",
    "api",
    "ai",
    "agent"
  ],
  "license": "MIT",
  "devDependencies": {
    "@prometheus/config-typescript": "workspace:*",
    "typescript": "^6.0.2"
  }
}
