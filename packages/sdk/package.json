{
  "name": "@prometheus/sdk",
  "version": "0.1.0",
  "description": "TypeScript client SDK for the Prometheus AI Engineering Platform API",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
