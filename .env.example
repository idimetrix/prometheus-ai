# ============================================================================
# Prometheus Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required vars are marked [REQUIRED], others are optional with defaults.
# ============================================================================

# ── General ──────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ── Database [REQUIRED] ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://prometheus:prometheus_dev@localhost:5432/prometheus
# Use pgBouncer for connection pooling in production:
# DATABASE_URL=postgresql://prometheus:prometheus_dev@localhost:6432/prometheus

# ── Redis [REQUIRED] ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Encryption [REQUIRED] ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── Clerk Auth [REQUIRED] ───────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Stripe Billing [REQUIRED for billing] ───────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_TEAM=price_xxx
STRIPE_PRICE_STUDIO=price_xxx
STRIPE_PRICE_CREDITS_100=price_xxx
STRIPE_PRICE_CREDITS_500=price_xxx
STRIPE_PRICE_CREDITS_1000=price_xxx
STRIPE_PRICE_CREDITS_5000=price_xxx

# ── LLM Providers ───────────────────────────────────────────────────────────
# Ollama — local inference [REQUIRED]
OLLAMA_BASE_URL=http://localhost:11434

# Cerebras — fast large model inference [Recommended, free tier]
CEREBRAS_API_KEY=

# Groq — fast inference fallback [Recommended, free tier]
GROQ_API_KEY=

# Google Gemini — long context processing [Recommended, free tier]
GEMINI_API_KEY=

# Anthropic — premium/vision/review [Recommended]
ANTHROPIC_API_KEY=

# OpenAI — optional
OPENAI_API_KEY=

# OpenRouter — optional multi-model gateway
OPENROUTER_API_KEY=

# Mistral — optional
MISTRAL_API_KEY=

# DeepSeek — optional cheap coding models
DEEPSEEK_API_KEY=

# ── App URLs ────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4001
CORS_ORIGIN=http://localhost:3000
# API_URL is the internal (server-side) API URL for Next.js SSR
API_URL=http://localhost:4000

# ── Service URLs (internal) ─────────────────────────────────────────────────
ORCHESTRATOR_URL=http://localhost:4002
PROJECT_BRAIN_URL=http://localhost:4003
MODEL_ROUTER_URL=http://localhost:4004
MCP_GATEWAY_URL=http://localhost:4005
SANDBOX_MANAGER_URL=http://localhost:4006

# ── Service Ports ───────────────────────────────────────────────────────────
PORT=4000
SOCKET_PORT=4001
ORCHESTRATOR_PORT=4002
PROJECT_BRAIN_PORT=4003
MODEL_ROUTER_PORT=4004
MCP_GATEWAY_PORT=4005
SANDBOX_MANAGER_PORT=4006

# ── Worker Config ───────────────────────────────────────────────────────────
WORKER_CONCURRENCY=2
ENTERPRISE_CONCURRENCY=4

# ── Sandbox Manager Config ──────────────────────────────────────────────────
WARM_POOL_SIZE=2
MAX_POOL_SIZE=10
SANDBOX_IDLE_TTL_MS=1800000
SANDBOX_IMAGE=node:22-alpine
SANDBOX_BASE_DIR=/tmp/prometheus-sandboxes

# ── Project Brain Config ────────────────────────────────────────────────────
EMBEDDING_MODEL=nomic-embed-text

# ── Email (optional) ────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Internal Service Communication ─────────────────────────────────────────
INTERNAL_SERVICE_SECRET=
SOCKET_SERVER_URL=http://localhost:4001

# ── Webhook Secrets ────────────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_ORG_ID=
JIRA_WEBHOOK_SECRET=
JIRA_DEFAULT_ORG_ID=

# ── Queue Worker Health ────────────────────────────────────────────────────
HEALTH_PORT=4007

# ── Concurrency Overrides ─────────────────────────────────────────────────
INDEXING_CONCURRENCY=2
EMBEDDINGS_CONCURRENCY=2
NOTIFICATION_CONCURRENCY=4
CLEANUP_CONCURRENCY=1
BILLING_CONCURRENCY=2

# ── Analytics (optional) ──────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ── Push Notifications (optional) ─────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ── MCP Adapter Credentials (optional) ────────────────────────────────────
CONFLUENCE_TOKEN=
CONFLUENCE_CLOUD_ID=
DATADOG_API_KEY=
DATADOG_APP_KEY=
SENTRY_TOKEN=
SENTRY_ORG=
DOCKERHUB_TOKEN=
DOCKERHUB_NAMESPACE=

# ── Deployment (optional) ─────────────────────────────────────────────────
VERCEL_TOKEN=
NETLIFY_TOKEN=
APP_VERSION=0.0.0

# ── Monitoring (optional) ─────────────────────────────────────────────────
SENTRY_DSN=
