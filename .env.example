# ============================================================================
# Prometheus Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required vars are marked [REQUIRED], others are optional with defaults.
# ============================================================================

# ── General ──────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ── Dev Mode Bypasses ────────────────────────────────────────────────────────
# Enable these for local development without Clerk/Stripe/LLM accounts.
# NEVER set these in production.
# Use Bearer token: dev_token_<userId> (e.g., dev_token_usr_seed_dev001)
DEV_AUTH_BYPASS=true
# Web app dev auth (client-side env var — must be NEXT_PUBLIC_)
NEXT_PUBLIC_DEV_AUTH_BYPASS=true
# Return canned LLM responses instead of calling real providers
DEV_MOCK_LLM=true

# ── Database [REQUIRED] ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://prometheus:prometheus_dev@localhost:5432/prometheus
# Use pgBouncer for connection pooling in production:
# DATABASE_URL=postgresql://prometheus:prometheus_dev@localhost:6432/prometheus

# ── Redis [REQUIRED] ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Redis password (optional, for authenticated Redis instances)
REDIS_PASSWORD=
# Redis Cluster (optional, comma-separated host:port pairs)
# REDIS_CLUSTER_NODES=host1:6379,host2:6379,host3:6379
# REDIS_CLUSTER_NAT_MAP=
# Redis Sentinel (optional)
# REDIS_SENTINEL_HOSTS=host1:26379,host2:26379
REDIS_SENTINEL_MASTER=prometheus-primary
# REDIS_SENTINEL_PASSWORD=

# ── Encryption [REQUIRED] ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
# KMS master key for envelope encryption (optional, falls back to ENCRYPTION_KEY)
KMS_MASTER_KEY=

# ── Clerk Auth [REQUIRED] ───────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Stripe Billing [REQUIRED for billing] ───────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_TEAM=price_xxx
STRIPE_PRICE_STUDIO=price_xxx
STRIPE_PRICE_CREDITS_100=price_xxx

# ── LLM Providers ───────────────────────────────────────────────────────────
# Ollama — local inference [REQUIRED]
OLLAMA_BASE_URL=http://localhost:11434

# Cerebras — fast large model inference [Recommended, free tier]
CEREBRAS_API_KEY=

# Groq — fast inference fallback [Recommended, free tier]
GROQ_API_KEY=

# Google Gemini — long context processing [Recommended, free tier]
GEMINI_API_KEY=

# Anthropic — premium/vision/review [Recommended]
ANTHROPIC_API_KEY=

# OpenAI — optional
OPENAI_API_KEY=

# OpenRouter — optional multi-model gateway
OPENROUTER_API_KEY=

# Mistral — optional
MISTRAL_API_KEY=

# DeepSeek — optional cheap coding models
DEEPSEEK_API_KEY=

# ── App URLs ────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4001
NEXT_PUBLIC_MCP_GATEWAY_URL=http://localhost:4005
CORS_ORIGIN=http://localhost:3000
# API_URL is the internal (server-side) API URL for Next.js SSR
API_URL=http://localhost:4000

# ── Service URLs (internal) ─────────────────────────────────────────────────
ORCHESTRATOR_URL=http://localhost:4002
PROJECT_BRAIN_URL=http://localhost:4003
MODEL_ROUTER_URL=http://localhost:4004
MCP_GATEWAY_URL=http://localhost:4005
SANDBOX_MANAGER_URL=http://localhost:4006

# ── Service Ports ───────────────────────────────────────────────────────────
PORT=4000
SOCKET_PORT=4001
ORCHESTRATOR_PORT=4002
PROJECT_BRAIN_PORT=4003
MODEL_ROUTER_PORT=4004
MCP_GATEWAY_PORT=4005
SANDBOX_MANAGER_PORT=4006

# ── Worker Config ───────────────────────────────────────────────────────────
WORKER_CONCURRENCY=2
ENTERPRISE_CONCURRENCY=4

# ── Sandbox Manager Config ──────────────────────────────────────────────────
WARM_POOL_SIZE=2
MAX_POOL_SIZE=10
SANDBOX_IDLE_TTL_MS=1800000
SANDBOX_IMAGE=node:22-alpine
SANDBOX_BASE_DIR=/tmp/prometheus-sandboxes

# ── Project Brain Config ────────────────────────────────────────────────────
EMBEDDING_MODEL=nomic-embed-text

# ── Email (optional) ────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=Prometheus <noreply@prometheus.dev>

# ── Internal Service Communication ─────────────────────────────────────────
INTERNAL_SERVICE_SECRET=
SOCKET_SERVER_URL=http://localhost:4001

# ── Webhook Secrets ────────────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_ORG_ID=
JIRA_WEBHOOK_SECRET=
JIRA_DEFAULT_ORG_ID=
CUSTOM_WEBHOOK_SECRET=

# ── Queue Worker Health ────────────────────────────────────────────────────
HEALTH_PORT=4007

# ── Concurrency Overrides ─────────────────────────────────────────────────
INDEXING_CONCURRENCY=2
EMBEDDINGS_CONCURRENCY=2
NOTIFICATION_CONCURRENCY=4
CLEANUP_CONCURRENCY=1
BILLING_CONCURRENCY=2

# ── Analytics (optional) ──────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ── Push Notifications (optional) ─────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ── MCP Adapter Credentials (optional) ────────────────────────────────────
CONFLUENCE_TOKEN=
CONFLUENCE_CLOUD_ID=
DATADOG_API_KEY=
DATADOG_APP_KEY=
SENTRY_TOKEN=
SENTRY_ORG=
DOCKERHUB_TOKEN=
DOCKERHUB_NAMESPACE=

# ── Web Search (optional) ─────────────────────────────────────────────────
# Tavily API key for high-quality web search (primary backend)
TAVILY_API_KEY=
# SearXNG instance URL for self-hosted web search (secondary backend)
SEARXNG_URL=

# ── Deployment (optional) ─────────────────────────────────────────────────
VERCEL_TOKEN=
VERCEL_TEAM_ID=
NETLIFY_TOKEN=
APP_VERSION=0.0.0

# ── Monitoring (optional) ─────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SDK_DISABLED=true

# ── LiteLLM Gateway ──────────────────────────────────────────────────────
LITELLM_URL=http://localhost:4010
LITELLM_API_KEY=sk-prometheus-litellm-dev

# ── Voyage Embeddings (optional) ─────────────────────────────────────────
VOYAGE_API_KEY=

# ── Vector DB / Memory (optional) ────────────────────────────────────────
MEM0_URL=http://localhost:6333
MEM0_API_KEY=
ZOEKT_URL=http://localhost:6070
ZOEKT_INDEX_DIR=/tmp/zoekt-index

# ── Object Storage (optional) ────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=prometheus

# ── Service Auth ─────────────────────────────────────────────────────────
SERVICE_AUTH_SECRET=
JWT_SECRET=

# ── GitHub Integration (optional) ────────────────────────────────────────
GITHUB_TOKEN=
SLACK_BOT_TOKEN=
SLACK_TOKEN=

# ── OAuth Providers (optional) ──────────────────────────────────────────
# GitHub OAuth — used by apps/api OAuth flow
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:4000/oauth/github/callback
# GitLab OAuth
GITLAB_OAUTH_CLIENT_ID=
GITLAB_OAUTH_CLIENT_SECRET=
GITLAB_OAUTH_REDIRECT_URI=http://localhost:4000/oauth/gitlab/callback
# Bitbucket OAuth
BITBUCKET_OAUTH_CLIENT_ID=
BITBUCKET_OAUTH_CLIENT_SECRET=
BITBUCKET_OAUTH_REDIRECT_URI=http://localhost:4000/oauth/bitbucket/callback

# ── Sandbox Providers (optional) ─────────────────────────────────────────
# Use "dev" for local temp-dir sandbox (no Docker needed), "docker" for containers
SANDBOX_MODE=dev
E2B_API_KEY=
FIRECRACKER_API_BASE=

# ── Feature Flags ────────────────────────────────────────────────────────
PROMETHEUS_USE_AI_SDK=false

# ── Langfuse Tracing (optional) ──────────────────────────────────────────
LANGFUSE_BASE_URL=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Database Pool Tuning ─────────────────────────────────────────────────
DB_POOL_SIZE=20
DB_IDLE_TIMEOUT=30000
DB_CONNECT_TIMEOUT=5000
DB_SLOW_QUERY_THRESHOLD_MS=500
DB_QUERY_LOGGING=false
DB_READ_POOL_SIZE=20
PGBOUNCER_URL=postgresql://prometheus:prometheus_dev@localhost:6432/prometheus
DATABASE_READ_URL=
DATABASE_READ_REPLICA_URL=

# ── Model Router ─────────────────────────────────────────────────────────
MODEL_KEY_ENCRYPTION_KEY=

# ── Queue Worker Health ──────────────────────────────────────────────────
QUEUE_WORKER_URL=http://localhost:4007

# ── Web App Public URLs ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:4001
WEB_URL=http://localhost:3000
NEXT_PUBLIC_PREVIEW_URL=

# ── Novu Notifications (optional) ────────────────────────────────────────
NOVU_API_KEY=
NOVU_URL=

# ── Auth Providers (optional) ────────────────────────────────────────────
OPENFGA_API_URL=
OPENFGA_STORE_ID=
OPENFGA_MODEL_ID=

# ── Cloud Deployment (optional) ──────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
HEROKU_API_KEY=

# ── Stripe Credit Packs (additional) ────────────────────────────────────
STRIPE_PRICE_CREDITS_300=price_xxx
STRIPE_PRICE_CREDITS_750=price_xxx
STRIPE_PRICE_CREDITS_2000=price_xxx

# ── Voice / Speech (optional) ──────────────────────────────────────────
WHISPER_URL=http://localhost:8080/v1/audio/transcriptions
DEEPGRAM_URL=https://api.deepgram.com/v1/listen
KOKORO_URL=http://localhost:8081/v1/audio/speech
ELEVENLABS_URL=https://api.elevenlabs.io/v1/text-to-speech
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Queue Worker (optional) ────────────────────────────────────────────
INNGEST_PORT=4008
WORKFLOW_ENGINE=

# ── CLI (optional) ─────────────────────────────────────────────────────
PROMETHEUS_API_URL=http://localhost:4000
PROMETHEUS_API_KEY=
PROMETHEUS_PROJECT_ID=

# ── Web App Logging (optional) ─────────────────────────────────────────
NEXT_PUBLIC_LOG_LEVEL=info

# ── Testing (optional) ─────────────────────────────────────────────────
PLAYWRIGHT_BASE_URL=http://localhost:3000
